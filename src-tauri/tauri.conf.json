{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/elements/lib/tauri/schema.json",
  "productName": "QoderWork Switcher",
  "version": "1.0.1",
  "identifier": "com.wanghaochen.qw-switcher",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QoderWork CN 账号切换器",
        "width": 420,
        "height": 650,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
